{
    "name": "musicno1/musicno1",
    "type": "project",
    "description": "The online music streaming website is built with PHP.",
    "license": "MIT",
    "require": {
        "haudevw3/foundation": "^1.0.8",
        "google/apiclient": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/",
            "Modules\\Adm\\": "modules/adm/",
            "Modules\\Album\\": "modules/album/",
            "Modules\\Artist\\": "modules/artist/",
            "Modules\\Categories\\": "modules/categories/",
            "Modules\\Page\\": "modules/page/",
            "Modules\\Song\\": "modules/song/",
            "Modules\\User\\": "modules/user/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
